# ─── Required ─────────────────────────────────────────────────
# Sarvam AI — for transcription (sarvam.ai → sign up → API Keys)
SARVAM_API_KEY=your_sarvam_key_here

# Anthropic Claude — for generating notes (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Optional: Notion Push ────────────────────────────────────
# Only needed if you want to push meeting notes + action items to Notion.
# Leave blank to skip Notion entirely — the tool still works without it.

# Notion Integration token (notion.so/my-integrations → New integration)
NOTION_KEY=

# ID of your Meetings database in Notion
# (open the DB page → copy the long ID from the URL before the ?v=)
NOTION_DB_ID=

# Auto-populated on first run — leave blank
NOTION_ACTION_ITEMS_DB_ID=

# ─── Optional: Port ───────────────────────────────────────────
# The app auto-finds a free port starting at 8000.
# Set this if you always want a specific port (e.g. another app uses 8000).
# PORT=8001
